# ──────────────────────────────────────────────
# SAGRES Monitoria — .gitignore (monorepo)
# ──────────────────────────────────────────────

# ===== JAVA / SPRING BOOT =====
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

.mvn/
mvnw
mvnw.cmd

.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

.classpath
.project
.settings/
.factorypath

*.iml
*.ipr
*.iws
.idea/
*.orig

# Spring Boot secrets — NUNCA commitar
backend/src/main/resources/application-dev.properties
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-secrets.properties

# ===== NODE / REACT / VITE =====
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/
.vite/
.cache/

# Variáveis de ambiente — NUNCA commitar
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== SISTEMA OPERACIONAL =====
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ===== DOCKER =====
# Manter docker-compose.yml no git, mas ignorar dados locais
postgres_data/
mailpit_data/

# ===== COVERAGE / TESTES =====
coverage/
*.lcov
.nyc_output/

# ===== MISC =====
*.log
*.pid
*.seed
*.pid.lock
